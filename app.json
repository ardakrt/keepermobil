{
  "expo": {
    "scheme": [
      "keeper",
      "kisiselnot",
      "com.keeperapp.test"
    ],
    "name": "Keeper",
    "slug": "test",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.keeperapp.test",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.USE_EXACT_ALARM",
        "android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.WAKE_LOCK"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "kisiselnot"
            },
            {
              "scheme": "keeper"
            },
            {
              "scheme": "https",
              "host": "kisiselnotkasasi.page.link",
              "pathPrefix": "/"
            },
            {
              "scheme": "https",
              "host": "ardakaratas.com.tr",
              "pathPrefix": "/auth"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "8cb3dbf4-6cd2-45ef-a7c6-d4f05e897210"
      },
      "resetRedirectBase": "https://ardakaratas.com.tr"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#ffffff"
        }
      ],
      [
        "@react-native-firebase/app",
        {
          "android": {
            "googleServicesFile": "./google-services.json"
          },
          "ios": {
            "googleServicesFile": "./GoogleService-Info.plist"
          }
        }
      ],
      "@react-native-firebase/messaging",
      "@react-native-google-signin/google-signin",
      "expo-secure-store",
      "./plugins/withAndroidManifestFix.js",
      "expo-web-browser"
    ],
    "owner": "ardkaratas"
  }
}